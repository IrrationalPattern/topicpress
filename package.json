    "eslint": "^9.25.1",
    "eslint-config-next": "^15.3.1",
    "prettier": "^3.5.3",
    "supabase": "^2.95.3",
    "tsx": "^4.19.4",
    "turbo": "^2.5.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0"
  }
