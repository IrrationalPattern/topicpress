# Public web origin used by Next.js metadata and local previews.
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Local-only database URL for Drizzle commands.
# Copy this file to an ignored .env file and replace placeholders with values
# from `pnpm supabase:status` after `pnpm supabase:start`.
DATABASE_URL=postgresql://postgres:<local-db-password>@127.0.0.1:54322/postgres
SUPABASE_DB_URL=postgresql://postgres:<local-db-password>@127.0.0.1:54322/postgres

# Local Supabase API values for app/worker development.
# Do not commit generated anon, service-role, or JWT secrets.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<local-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<local-service-role-key>

# Optional local-only live AI provider settings. Fixture-backed generation is the default.
# Keep real OpenAI service-account API keys in ignored local env files only.
TOPICPRESS_AI_PROVIDER=fixture
TOPICPRESS_AI_LIVE_ENABLED=false
TOPICPRESS_OPENAI_MODEL=gpt-5.5
TOPICPRESS_OPENAI_TIMEOUT_MS=60000
TOPICPRESS_OPENAI_IMAGE_MODEL=gpt-image-1.5
TOPICPRESS_OPENAI_IMAGE_TIMEOUT_MS=60000
OPENAI_API_KEY=<local-openai-service-account-api-key>
