{
  "name": "@topicpress/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx src/index.ts",
    "ingest": "tsx src/ingest.cli.ts",
    "seed:sync": "tsx src/seed-sync.cli.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "tsc -p tsconfig.json && node test/seed-sync.test.mjs && node test/feed-ingestion.test.mjs && node test/source-item-persistence.test.mjs && node test/clustering.test.mjs && node test/ingestion-run.test.mjs && node test/ingest-cli.test.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@topicpress/config": "workspace:*",
    "@topicpress/db": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.7"
  }
}
